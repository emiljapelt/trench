
let end_test = \() {
    let b = 0;
    let a = 1 / b;
};

int current_test;
int assertions;
int has_failed;

let assert = \(int v) {
    if (has_failed) return 0;
    assertions++;
    if (v) return 0;
    else {
        has_failed = 1;
        say((current_test * 1000) + assertions);
    }
};

let test_case = \(int test_id, int() test) {
    current_test = test_id;
    has_failed = 0;
    assertions = 0;
    pass();
    test();
};

let clone = \(int() f) {
    let _id = id;
    projection();
    if (_id == id) return 0;
    else f();
};

// START


// move
test_case(1, \() {
    let prev_y = y;
    let prev_x = x;
    wall(N);
    wall(E);
    assert(!move(N));
    assert(!move(E));
    assert(prev_y == y);
    assert(prev_x == x);
    fireball(N);
    fireball(E);
    assert(move(N));
    assert(move(E));
    assert(prev_y != y);
    assert(prev_x != x);
});


// pager
test_case(2, \() {
    pager_set(1337);

    clone(\() {
        pager_write(123);
        end_test();
    });

    repeat 2 pass();
    assert(pager_read() == 123);

    clone(\() {
        pager_write(123);
        end_test();
    });

    pager_set(420);
    repeat 2 pass();
    assert(pager_read() == 0);
});


// bridge/ocean
test_case(3, \() {
    while(!(scan(W, 1) is @ocean)) move(W);

    clone(\() {
        move(W);
        pager_write(420);
        end_test();
    });
    repeat 2 pass();
    assert(pager_read() == 0);

    bridge(W);

    clone(\() {
        move(W);
        pager_write(420);
        end_test();
    });
    repeat 2 pass();
    assert(pager_read() == 420);

    bomb(W, 1);

    clone(\() {
        move(W);
        pager_write(420);
        end_test();
    });
    repeat 2 pass();
    assert(pager_read() == 0);
});

// Tree
test_case(4, \() {
    int prev = count(#sapling);
    plant_tree(E);
    assert(count(#sapling) < prev);
    repeat 3 pass();

    assert(scan(E, 1) is @tree);

    prev = x;
    move(E);
    assert(x == prev);

    prev = count(#sapling);
    collect(E);
    assert(count(#sapling) > prev);

    prev = count(#wood);
    chop(E);
    assert(count(#wood) > prev);
    assert(!(scan(E, 1) is @tree));

    let prev = x;
    move(E);
    assert(x != prev);
});

// Drop resources on death
test_case(5, \() {
    assert(search(#wood) == 0);
    drop(1, #wood);
    assert(search(#wood) == 1);

    clone(\() {
        assert(search(#wood) == 1);
        let prev = count(#wood);
        take(1, #wood);
        assert(count(#wood) == prev + 1);
        assert(search(#wood) == 0);
        move(E);
        end_test();
    });

    repeat 2 pass();

    let prev = count(#wood);
    assert(search(#wood) == 0);
    take(1, #wood);
    assert(search(#wood) == 0);
    assert(count(#wood) == prev);

    move(E);
    let prev_search = search(#wood);
    assert(prev_search != 0);
    take(1, #wood);
    assert(search(#wood) == prev_search - 1);
    assert(count(#wood) == prev + 1);
});

// Can use boat
test_case(6, \() {
    while(!(scan(W, 1) is @ocean)) move(W);

    boat(W);
    assert(mount(W));
    assert(move(W));
    assert(move(E));
    assert(move(E) == _OBSTRUCTED);
    assert(dismount(E));
});

// stack overflow kills
test_case(7, \() {

    write(1);
    clone(\() {
        if (read() == 1) {
            write(0);
            pass(); 
        }
        this();
    });

    move(S);
    assert(look(N, @player));
    repeat 5 pass();
    assert(look(N, @player) == _OUT_OF_BOUNDS);
});

// function usage
test_case(8, \() {

    let both = \int:(int a, int b) {
        return a ? b : 0;
    };

    let either = \int:(int a, int b) {
        return a ? 1 : b;
    };

    let not = \int:(int a) {
        return !a;
    };

    assert(
        both(
            not(0),
            either(
                not(1),
                both(1, 1)
            )
        )
    );

    assert(
        not(
            both(1,0)
        )
    );

    assert(not(-1));

    assert(either(1, -1));

    assert(not(both(1, -1)));

    assert(true);
    assert(!false);
});

// null test
test_case(9, \() {
    int() f;

    assert(f == null);

    f = \int:() { return 1; };

    assert(f != null);

    f = null;

    assert(f == null);
});

// can pass builtin functions
test_case(10, \() {

    let f = \int:(int(dir) f) {
        return f(N);
    };

    let _y = y;
    assert(f(move));
    assert(y == _y - 1);


    let f = move;

    _y = y;
    assert(f(S));
    assert(y == _y + 1);
});

// array bounds check

test_case(11, \() {

    clone(\() {
        int[2] arr;
        while(pager_read() != 1) pass();

        arr[-1] = 1;
    });

    move(S);
    assert(look(N, @player));
    pager_write(1);
    repeat 2 pass();
    assert(look(N, @player) == _OUT_OF_BOUNDS);

});

// scope test
let a = 1;
test_case(12, \() {
    assert(a == 1);
    let a = 2;
    assert(a == 2);
    {
        assert(a == 2);
        let a = 3;
        assert(a == 3);
    }
    assert(a == 2);

    if true {
        assert(a == 2);
        let a = 3;
        assert(a == 3);
    }
    assert(a == 2);
});

// arithmatics
test_case(12, \() {
    int a;

    assert(a++ == 0);
    assert(a == 1);
    assert(a-- == 1);
    assert(a == 0);

    assert(++a == 1);
    assert(a == 1);
    assert(--a == 0);
    assert(a == 0);
});

end_test();